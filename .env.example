# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retailpulse
DB_USER=postgres
DB_PASSWORD=your_password

# MLflow Configuration
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_REGISTRY_URI=./model_registry

# API Keys & Secrets
API_KEY=your_api_key_here
JWT_SECRET=your_jwt_secret_here

# Environment
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG

# Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring
PROMETHEUS_ENABLED=False
ALERT_EMAIL=alerts@zidio.dev
